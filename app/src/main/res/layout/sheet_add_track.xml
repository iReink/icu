<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingStart="32dp"
    android:paddingTop="12dp"
    android:paddingEnd="32dp"
    android:paddingBottom="44dp">

    <View
        android:layout_width="56dp"
        android:layout_height="6dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="26dp"
        android:background="@drawable/bg_sheet_handle" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="28dp"
        android:text="@string/add_track"
        android:textColor="@color/black"
        android:textSize="34sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/walkTrackButton"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:text="@string/walk"
        android:textAllCaps="false"
        android:textColor="@color/icu_text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        app:backgroundTint="@color/icu_purple_surface"
        app:cornerRadius="10dp"
        app:icon="@drawable/ic_walk"
        app:iconGravity="textStart"
        app:iconPadding="16dp"
        app:iconSize="34dp"
        app:iconTint="@color/icu_text_primary"
        app:strokeColor="@color/black"
        app:strokeWidth="3dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/bikeTrackButton"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:layout_marginTop="24dp"
        android:text="@string/bike"
        android:textAllCaps="false"
        android:textColor="@color/icu_text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        app:backgroundTint="@color/icu_purple_surface"
        app:cornerRadius="10dp"
        app:icon="@drawable/ic_bike"
        app:iconGravity="textStart"
        app:iconPadding="16dp"
        app:iconSize="34dp"
        app:iconTint="@color/icu_text_primary"
        app:strokeColor="@color/icu_blue_track"
        app:strokeWidth="3dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="28dp"
        android:layout_marginBottom="28dp"
        android:background="@color/icu_sheet_divider" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/uploadTrackButton"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="match_parent"
        android:layout_height="76dp"
        android:text="@string/upload"
        android:textAllCaps="false"
        android:textColor="@color/icu_text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        app:backgroundTint="@color/icu_upload_disabled"
        app:cornerRadius="10dp"
        app:icon="@drawable/ic_upload"
        app:iconGravity="textStart"
        app:iconPadding="16dp"
        app:iconSize="34dp"
        app:iconTint="@color/icu_text_primary" />
</LinearLayout>
