<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingStart="32dp"
    android:paddingTop="12dp"
    android:paddingEnd="32dp"
    android:paddingBottom="44dp">

    <View
        android:layout_width="56dp"
        android:layout_height="6dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="26dp"
        android:background="@drawable/bg_sheet_handle" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="28dp"
        android:text="@string/add_track"
        android:textColor="@color/black"
        android:textSize="28sp" />

    <RadioGroup
        android:id="@+id/addTrackTypeGroup"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:orientation="vertical">

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/walkTrackRadio"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:checked="true"
            android:gravity="center_vertical"
            android:text="@string/walk"
            android:textColor="@color/icu_text_primary"
            android:textSize="16sp" />

        <com.google.android.material.radiobutton.MaterialRadioButton
            android:id="@+id/bikeTrackRadio"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            android:text="@string/bike"
            android:textColor="@color/icu_text_primary"
            android:textSize="16sp" />
    </RadioGroup>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="28dp"
        android:layout_marginBottom="28dp"
        android:background="@color/icu_sheet_divider" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/uploadTrackButton"
        style="@style/Widget.MaterialComponents.Button"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/upload"
        android:textAllCaps="false"
        android:textColor="@color/icu_text_primary"
        android:letterSpacing="0"
        android:textSize="16sp"
        app:backgroundTint="@color/icu_upload_disabled"
        app:cornerRadius="10dp"
        app:icon="@drawable/ic_upload"
        app:iconGravity="textStart"
        app:iconPadding="12dp"
        app:iconSize="26dp"
        app:iconTint="@color/icu_text_primary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gravity="center_vertical|end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/cancelAddTrackButton"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="@string/cancel"
            android:textAllCaps="false"
            android:textColor="@color/icu_purple_ink" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/startTrackButton"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/start_recording"
            android:textAllCaps="false" />
    </LinearLayout>
</LinearLayout>
